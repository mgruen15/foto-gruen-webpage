---
import Layout from './Layout.astro';
import PageHero from '../components/PageHero.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  heading: string;
  lead?: string;
  toc?: { id: string; label: string }[];
}
const { title, description, eyebrow = 'Rechtliches', heading, lead, toc } = Astro.props;
---

<Layout title={title} description={description} fullWidth>
  <PageHero slot="hero" eyebrow={eyebrow} title={heading} lead={lead} />

  <div class="legal">
    {
      toc && toc.length > 0 && (
        <nav class="legal__toc" aria-label="Inhaltsverzeichnis">
          <h2 class="legal__toc-title">Inhalt</h2>
          <ol>
            {toc.map((t) => (
              <li><a class="link-underline" href={`#${t.id}`}>{t.label}</a></li>
            ))}
          </ol>
        </nav>
      )
    }
    <article class="legal__body prose">
      <slot />
    </article>
  </div>
</Layout>

<style>
  .legal {
    display: grid;
    grid-template-columns: 16rem 1fr;
    gap: clamp(1.5rem, 1rem + 3vw, 4rem);
    align-items: start;
  }
  @media (max-width: 820px) {
    .legal {
      grid-template-columns: 1fr;
    }
  }
  .legal__toc {
    position: sticky;
    top: 6rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  @media (max-width: 820px) {
    .legal__toc {
      position: static;
    }
  }
  .legal__toc-title {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .legal__toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: toc;
    display: grid;
    gap: 0.55rem;
  }
  .legal__toc li {
    counter-increment: toc;
    font-size: 0.88rem;
  }
  .legal__toc li::before {
    content: counter(toc) '. ';
    color: var(--accent);
    font-weight: 600;
  }
  .legal__body {
    max-width: 70ch;
  }
  .legal__body :global(h2) {
    scroll-margin-top: 6rem;
    font-size: var(--step-1);
    padding-top: 0.5rem;
  }
  .legal__body :global(h3) {
    font-size: 1.15rem;
  }
  .legal__body :global(address) {
    font-style: normal;
    font-family: var(--font-display);
    font-size: 1.1rem;
    line-height: 1.6;
  }
</style>
