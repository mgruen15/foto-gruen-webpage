---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<header class="page-hero">
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="page-hero__title">{title}</h1>
    {lead && <p class="page-hero__lead">{lead}</p>}
  </div>
</header>

<style>
  .page-hero {
    padding-block: clamp(2.25rem, 1.5rem + 3vw, 4rem) clamp(1.5rem, 1rem + 2vw, 2.5rem);
    border-bottom: 1px solid var(--line);
  }
  .page-hero__title {
    margin-top: 0.9rem;
    font-size: var(--step-3);
  }
  .page-hero__lead {
    margin-top: 1rem;
    max-width: 56ch;
    font-size: var(--step-1);
    color: var(--ink-soft);
    line-height: 1.4;
  }
</style>
