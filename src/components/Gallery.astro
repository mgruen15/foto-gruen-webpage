---
import { Image, getImage } from 'astro:assets';
import type { Gallery } from '../data/galleries';
import { img } from '../lib/images';

interface Props {
  gallery: Gallery;
}
const { gallery } = Astro.props;

// Resolve medium (grid) + large (lightbox) variants for every item.
const items = await Promise.all(
  gallery.items.map(async (file, idx) => {
    const thumb = img(`phocagallery/${gallery.dir}/thumbs/phoca_thumb_m_${file}`);
    const largeMeta = img(`phocagallery/${gallery.dir}/thumbs/phoca_thumb_l_${file}`);
    const large = await getImage({ src: largeMeta, widths: [largeMeta.width], format: 'webp' });
    return {
      thumb,
      largeSrc: large.src,
      alt: `${gallery.title} – Bild ${idx + 1}`,
    };
  }),
);
---

<div class="gallery" data-gallery>
  {
    items.map((item, i) => (
      <button
        class="gallery__item img-frame"
        type="button"
        data-index={i}
        data-full={item.largeSrc}
        aria-label={`${item.alt} vergrößern`}
      >
        <Image
          src={item.thumb}
          alt={item.alt}
          widths={[300, 500]}
          sizes="(max-width: 600px) 50vw, (max-width: 980px) 33vw, 280px"
          loading={i < 6 ? 'eager' : 'lazy'}
        />
        <span class="gallery__zoom" aria-hidden="true">+</span>
      </button>
    ))
  }
</div>

<!-- Lightbox -->
<div class="lightbox" data-lightbox hidden aria-hidden="true">
  <div class="lightbox__backdrop" data-lb-close></div>
  <div class="lightbox__dialog" role="dialog" aria-modal="true" aria-label="Bildansicht">
    <button class="lightbox__btn lightbox__close" type="button" data-lb-close aria-label="Schließen">×</button>
    <button class="lightbox__btn lightbox__prev" type="button" data-lb-prev aria-label="Vorheriges Bild">‹</button>
    <figure class="lightbox__figure">
      <img data-lb-img src="" alt="" />
    </figure>
    <button class="lightbox__btn lightbox__next" type="button" data-lb-next aria-label="Nächstes Bild">›</button>
    <p class="lightbox__counter" data-lb-counter></p>
  </div>
</div>

<style>
  /* Broken / staggered masonry via CSS columns */
  .gallery {
    columns: 4 16rem;
    column-gap: clamp(0.6rem, 0.4rem + 0.8vw, 1.1rem);
  }
  .gallery__item {
    display: block;
    width: 100%;
    margin: 0 0 clamp(0.6rem, 0.4rem + 0.8vw, 1.1rem);
    padding: 0;
    border: 0;
    cursor: zoom-in;
    background: var(--line);
    break-inside: avoid;
  }
  .gallery__zoom {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    font-size: 1.3rem;
    line-height: 1;
    color: #fff;
    background: var(--crimson);
    border-radius: 50%;
    opacity: 0;
    transform: scale(0.7);
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .gallery__item:hover .gallery__zoom,
  .gallery__item:focus-visible .gallery__zoom {
    opacity: 1;
    transform: scale(1);
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 18, 13, 0.92);
    animation: lb-fade 0.3s var(--ease);
  }
  @keyframes lb-fade {
    from {
      opacity: 0;
    }
  }
  .lightbox__dialog {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: clamp(0.25rem, 2vw, 1.5rem);
    width: min(96vw, 1400px);
    padding: 1rem;
  }
  .lightbox__figure {
    margin: 0;
    flex: 1;
    display: grid;
    place-items: center;
  }
  .lightbox__figure img {
    max-width: 100%;
    max-height: 84vh;
    width: auto;
    height: auto;
    border-radius: 2px;
    box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.8);
    animation: lb-zoom 0.35s var(--ease);
  }
  @keyframes lb-zoom {
    from {
      opacity: 0;
      transform: scale(0.96);
    }
  }
  .lightbox__btn {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 3rem;
    height: 3rem;
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .lightbox__btn:hover {
    background: var(--crimson);
    border-color: var(--crimson);
  }
  .lightbox__close {
    position: absolute;
    top: -0.5rem;
    right: 0.25rem;
    width: 2.75rem;
    height: 2.75rem;
    font-size: 1.5rem;
  }
  .lightbox__counter {
    position: absolute;
    bottom: -0.25rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }
  @media (max-width: 640px) {
    .lightbox__prev {
      position: absolute;
      left: 0.25rem;
      top: 50%;
    }
    .lightbox__next {
      position: absolute;
      right: 0.25rem;
      top: 50%;
    }
    .lightbox__dialog {
      padding: 0.5rem;
    }
  }
</style>

<script>
  type Slide = { src: string; alt: string };

  const galleryEl = document.querySelector<HTMLElement>('[data-gallery]');
  const lb = document.querySelector<HTMLElement>('[data-lightbox]');
  if (galleryEl && lb) {
    const triggers = Array.from(galleryEl.querySelectorAll<HTMLButtonElement>('[data-full]'));
    const slides: Slide[] = triggers.map((t) => ({
      src: t.dataset.full ?? '',
      alt: t.querySelector('img')?.alt ?? '',
    }));
    const imgEl = lb.querySelector<HTMLImageElement>('[data-lb-img]')!;
    const counter = lb.querySelector<HTMLElement>('[data-lb-counter]')!;
    let index = 0;
    let lastFocus: HTMLElement | null = null;

    function render() {
      const s = slides[index];
      imgEl.src = s.src;
      imgEl.alt = s.alt;
      counter.textContent = `${index + 1} / ${slides.length}`;
    }
    function open(i: number) {
      index = i;
      lastFocus = document.activeElement as HTMLElement;
      render();
      lb!.hidden = false;
      lb!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      lb!.querySelector<HTMLButtonElement>('[data-lb-next]')?.focus();
    }
    function close() {
      lb!.hidden = true;
      lb!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lastFocus?.focus();
    }
    const go = (d: number) => {
      index = (index + d + slides.length) % slides.length;
      render();
    };

    triggers.forEach((t, i) => t.addEventListener('click', () => open(i)));
    lb.querySelectorAll('[data-lb-close]').forEach((b) => b.addEventListener('click', close));
    lb.querySelector('[data-lb-prev]')?.addEventListener('click', () => go(-1));
    lb.querySelector('[data-lb-next]')?.addEventListener('click', () => go(1));

    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') go(-1);
      else if (e.key === 'ArrowRight') go(1);
    });

    // Touch swipe
    let startX = 0;
    lb.addEventListener('touchstart', (e) => (startX = e.touches[0].clientX), { passive: true });
    lb.addEventListener(
      'touchend',
      (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 50) go(dx < 0 ? 1 : -1);
      },
      { passive: true },
    );
  }
</script>
