---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import ContentImage from '../components/ContentImage.astro';
import { contact } from '../data/site';
---

<Layout
  title="Kontakt"
  description="Kontakt zum Fotostudio Roland Grün in Hanau-Großauheim. Telefon, Adresse und Kontaktformular."
>
  <PageHero
    slot="hero"
    eyebrow="Kontakt"
    title="Kontakt zu Foto Grün"
    lead="Wir freuen uns auf Ihre Anfrage – am schnellsten erreichen Sie uns telefonisch."
  />

  <div class="kontakt">
    <div class="kontakt__details">
      <dl class="contact-list">
        <div>
          <dt>Adresse</dt>
          <dd>{contact.street}<br />{contact.zip} {contact.town}</dd>
        </div>
        <div>
          <dt>Telefon</dt>
          <dd><a class="link-underline" href={contact.phoneHref}>{contact.phone}</a></dd>
        </div>
        <div>
          <dt>Telefax</dt>
          <dd>{contact.fax}</dd>
        </div>
        <div>
          <dt>Web</dt>
          <dd><a class="link-underline" href={contact.web}>{contact.webLabel}</a></dd>
        </div>
      </dl>

      <ContentImage
        src="bilder/beitraege/AbdiePost620.jpg"
        alt="Briefkasten – ab die Post"
        sizes="(max-width: 860px) 100vw, 30vw"
      />
    </div>

    <div class="kontakt__form">
      <h2>Schreiben Sie uns</h2>
      <ContactForm />
    </div>
  </div>
</Layout>

<style>
  .kontakt {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(1.5rem, 1rem + 3vw, 3.5rem);
    align-items: start;
  }
  @media (max-width: 860px) {
    .kontakt {
      grid-template-columns: 1fr;
    }
  }
  .kontakt__details {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .contact-list {
    display: grid;
    gap: 1rem;
    margin: 0;
  }
  .contact-list div {
    display: grid;
    gap: 0.15rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .contact-list dt {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .contact-list dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
  }
  .kontakt__form h2 {
    font-size: var(--step-1);
    margin-bottom: 1.25rem;
  }
</style>
